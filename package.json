{
  "name": "krishi-route-server",
  "version": "1.0.0",
  "description": "Krishi-Route Backend — Express + MongoDB + TypeScript",
  "private": true,
  "scripts": {
    "dev":        "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":      "tsc",
    "start":      "node dist/server.js",
    "seed":       "ts-node src/scripts/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express":        "^4.18.2",
    "mongoose":       "^8.1.1",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.1",
    "express-validator": "^7.0.1",
    "morgan":         "^1.10.0"
  },
  "devDependencies": {
    "@types/express":  "^4.17.21",
    "@types/cors":     "^2.8.17",
    "@types/morgan":   "^1.9.9",
    "@types/node":     "^20.11.0",
    "typescript":      "^5.3.3",
    "ts-node-dev":     "^2.0.0"
  }
}
